#!/usr/bin/env python3
"""uplinkmgr-setup — generate static config files from uplinkmgr.yaml."""

import argparse
import os
import subprocess
import sys

from uplinkmgr import config as cfg_mod
from uplinkmgr import naming, generator


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="Generate uplinkmgr config files from uplinkmgr.yaml"
    )
    p.add_argument(
        "--config",
        default=cfg_mod.DEFAULT_CONFIG_PATH,
        metavar="PATH",
        help=f"config file path (default: {cfg_mod.DEFAULT_CONFIG_PATH})",
    )
    p.add_argument(
        "--dry-run",
        action="store_true",
        help="print what would be written; write nothing to disk",
    )
    return p.parse_args()


def check_rt_conflicts(cfg, dry_run: bool) -> None:
    """Validate that uplinkmgr's table numbers/names don't conflict with existing entries."""
    import re

    our_nums = {
        naming.ipv6_table_num(cfg.routing_table_start, u.index)
        for u in cfg.uplinks
    }
    our_names = {naming.ipv6_table_name(u.name) for u in cfg.uplinks}

    rt_dirs = ["/etc/iproute2/rt_tables.d", "/etc/iproute2"]
    existing_nums: dict[int, str] = {}
    existing_names: dict[str, str] = {}

    for base in rt_dirs:
        import glob
        files = sorted(glob.glob(f"{base}/rt_tables*") + glob.glob(f"{base}/rt_tables.d/*"))
        for path in files:
            if "uplinkmgr" in path:
                continue  # our own file; expect overlap
            try:
                text = open(path).read()
            except OSError:
                continue
            for line in text.splitlines():
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                parts = line.split()
                if len(parts) < 2:
                    continue
                try:
                    num = int(parts[0])
                    name = parts[1]
                except ValueError:
                    continue
                existing_nums[num] = path
                existing_names[name] = path

    for num in our_nums:
        if num in existing_nums:
            _die(
                f"routing table number {num} already used in {existing_nums[num]}; "
                f"adjust routing_table_start"
            )
    for name in our_names:
        if name in existing_names:
            _die(
                f"routing table name '{name}' already used in {existing_names[name]}; "
                f"rename the uplink"
            )


def main() -> None:
    args = parse_args()
    cfg = cfg_mod.load(args.config)
    dry_run = args.dry_run

    try:
        naming.validate_macvlan_names(cfg)
    except ValueError as e:
        _die(str(e))

    if not dry_run:
        check_rt_conflicts(cfg, dry_run)

    # --- /etc/network/interfaces.d/uplinkmgr.conf ---
    generator.write_file(
        "/etc/network/interfaces.d/uplinkmgr.conf",
        generator.interfaces_file(cfg),
        dry_run,
    )

    # --- /etc/dhcpcd.conf ---
    _backup_dhcpcd_conf(dry_run)
    head = _read_optional_file("/etc/uplinkmgr/dhcpcd.conf.head")
    tail = _read_optional_file("/etc/uplinkmgr/dhcpcd.conf.tail")
    generator.write_file("/etc/dhcpcd.conf", generator.dhcpcd_conf(cfg, head=head, tail=tail), dry_run)

    # --- radvd per-uplink config files ---
    for uplink in cfg.uplinks:
        if uplink.ipv6_pd:
            generator.write_file(
                naming.radvd_conf_path(uplink.name),
                generator.radvd_conf(cfg, uplink),
                dry_run,
            )

    # --- routing table registration ---
    generator.write_file(
        "/etc/iproute2/rt_tables.d/uplinkmgr.conf",
        generator.rt_tables(cfg),
        dry_run,
    )

    # --- uplink env files and symlinks ---
    for uplink in cfg.uplinks:
        env_path = naming.env_file_path(uplink.name)
        generator.write_file(env_path, generator.env_file(cfg, uplink), dry_run)
        # symlink from WAN interface name to the env file
        generator.write_symlink(
            naming.env_symlink_path(uplink.interface),
            f"{uplink.name}.env",
            dry_run,
        )
        # symlinks from macvlan interface names
        if uplink.ipv6_pd:
            for net in cfg.networks:
                mv = naming.macvlan_name(net.interface, uplink.index)
                generator.write_symlink(
                    naming.env_symlink_path(mv),
                    f"{uplink.name}.env",
                    dry_run,
                )

    # --- clean up stale generated files ---
    if not dry_run:
        _remove_stale(cfg, {u.name for u in cfg.uplinks})


    # --- enable services ---
    if os.path.exists("/run/systemd/system"):
        for uplink in cfg.uplinks:
            _systemctl("enable", f"radvd-uplinkmgr@{uplink.name}.service", dry_run)
        _systemctl("enable", "dhcpcd.service", dry_run)
        _systemctl("restart", "dhcpcd.service", dry_run)
        for uplink in cfg.uplinks:
            _systemctl("start", f"radvd-uplinkmgr@{uplink.name}.service", dry_run)
        _systemctl("enable", "uplinkmgr.service", dry_run)
        _systemctl("restart", "uplinkmgr.service", dry_run)
        _disable_stale_radvd_units(cfg, dry_run)


def _systemctl(action: str, unit: str, dry_run: bool) -> None:
    if dry_run:
        print(f"[dry-run] would systemctl {action} {unit}")
        return

    result = subprocess.run(
        ["systemctl", action, unit],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.PIPE,
    )
    if result.returncode != 0:
        print(f"systemctl {action} {unit} failed: {result.stderr.decode().strip()}")


def _disable_stale_radvd_units(cfg, dry_run: bool) -> None:
    """Stop and disable radvd-uplinkmgr@ units for uplinks no longer configured."""
    current_units = {naming.radvd_unit_name(u.name) for u in cfg.uplinks}
    for unit in sorted(_list_radvd_units() - current_units):
        _systemctl("stop", unit, dry_run)
        _systemctl("disable", unit, dry_run)


def _list_radvd_units() -> set[str]:
    """Return names of all radvd-uplinkmgr@ instances systemd currently knows
    about, whether running, stopped, or merely enabled."""
    result = subprocess.run(
        ["systemctl", "list-units", "--all", "--plain", "--no-legend", "radvd-uplinkmgr@*"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    units: set[str] = set()
    for line in result.stdout.decode().splitlines():
        fields = line.split()
        if fields:
            units.add(fields[0])
    return units


def _read_optional_file(path: str) -> str:
    try:
        from pathlib import Path
        return Path(path).read_text()
    except FileNotFoundError:
        return ""


def _backup_dhcpcd_conf(dry_run: bool) -> None:
    import shutil
    src = "/etc/dhcpcd.conf"
    dst = "/etc/dhcpcd.conf.pre-uplinkmgr"
    if not os.path.exists(src):
        return
    if os.path.exists(dst):
        print(f"{dst} already exists; skipping backup")
        return
    with open(src) as f:
        if f.read(30).startswith("# Generated by uplinkmgr-setup"):
            return  # already ours; no backup needed
    if dry_run:
        print(f"[dry-run] would back up {src} -> {dst}")
        return
    shutil.copy2(src, dst)
    print(f"uplinkmgr-setup: backed up {src} -> {dst}")


def _remove_stale(cfg, current_uplink_names: set[str]) -> None:
    generator.remove_stale_files(
        "/etc/uplinkmgr/radvd", "radvd-uplinkmgr-", current_uplink_names, ".conf"
    )
    # Remove stale env files and their symlinks
    import os
    uplinks_dir = "/etc/uplinkmgr/uplinks"
    if os.path.isdir(uplinks_dir):
        for fname in os.listdir(uplinks_dir):
            if fname.endswith(".env") and not os.path.islink(f"{uplinks_dir}/{fname}"):
                uplink_name = fname[:-4]  # strip .env
                if uplink_name not in current_uplink_names:
                    os.unlink(f"{uplinks_dir}/{fname}")
        # Remove dangling symlinks
        for fname in os.listdir(uplinks_dir):
            fpath = f"{uplinks_dir}/{fname}"
            if os.path.islink(fpath) and not os.path.exists(fpath):
                os.unlink(fpath)


def _die(msg: str) -> None:
    print(f"uplinkmgr-setup: error: {msg}", file=sys.stderr)
    sys.exit(1)


if __name__ == "__main__":
    main()
