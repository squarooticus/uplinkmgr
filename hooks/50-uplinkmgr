#!/bin/sh
# dhcpcd exit hook for uplinkmgr
# Installed at /lib/dhcpcd/dhcpcd-hooks/50-uplinkmgr
# Sourced by dhcpcd on every lease event.

UPLINKMGR_ENV_DIR="${UPLINKMGR_ENV_DIR:-/etc/uplinkmgr/uplinks}"
UPLINKMGR_STATE_DIR="${UPLINKMGR_STATE_DIR:-/run/uplinkmgr}"
UPLINKMGR_PID_FILE="${UPLINKMGR_STATE_DIR}/uplinkmgr.pid"

_debug_log() {
    if [ -n "$UPLINKMGR_HOOK_LOG" ]; then
        echo "$@" >>"$UPLINKMGR_HOOK_LOG"
    fi
}

if [ -n "$UPLINKMGR_HOOK_LOG" ]; then
    printf '\n--- %s reason=%s interface=%s ---\n' \
        "$(date -Iseconds)" "$reason" "$interface" >> "$UPLINKMGR_HOOK_LOG"
    env | sort >> "$UPLINKMGR_HOOK_LOG"
fi

# --- Identify uplink ---

env_file="${UPLINKMGR_ENV_DIR}/${interface}.env"
[ -f "$env_file" ] || return 0
. "$env_file"

# Only process events on the WAN interface; macvlan events are ignored.
[ "$interface" = "$UPLINKMGR_WAN_IFACE" ] || return 0

_debug_log "$interface is WAN iface"

# --- Helpers ---

_signal_daemon() {
    if [ -f "$UPLINKMGR_PID_FILE" ]; then
        kill -USR1 "$(cat "$UPLINKMGR_PID_FILE")" 2>/dev/null || true
    fi
}

_write_state_file() {
    local _target="$1"; shift
    local _tmp="${_target}.tmp"
    printf "$@" > "$_tmp" && mv "$_tmp" "$_target"
}

# --- Dispatch ---

case "$reason" in

    # IPv4: write gateway state file and signal daemon
    BOUND|RENEW|REBIND|REBOOT)
        GW4="${new_routers%% *}"  # take first gateway
        [ -n "$GW4" ] || return 0

        mkdir -p "$UPLINKMGR_STATE_DIR"
        _write_state_file "${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv4.state" \
            'gateway=%s\naddress=%s\n' "$GW4" "${new_ip_address:-}"
        _signal_daemon
        ;;

    EXPIRE|RELEASE|STOP)
        rm -f "${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv4.state"
        _signal_daemon
        ;;

    # IPv6 router advertisement: write gateway state file and signal daemon
    ROUTERADVERT)
        [ "$UPLINKMGR_IPV6_PD" = true ] || [ "$UPLINKMGR_IPV6_IA_NA" = true ] || return 0

        _debug_log "wants IPv6 PD or NA"

        GW6="$nd1_from"
        ND1_LIFETIME="${nd1_lifetime:-0}"
        ND1_PREFIX="${nd1_prefix_information1_prefix:-}"
        ND1_PLEN="${nd1_prefix_information1_length:-0}"

        [ -n "$GW6" ] || return 0

        _debug_log "has GW6 $GW6"

        # M flag: DHCPv6 assigns addresses; address comes from IA_NA (ipv6na.state).
        # No M flag: SLAAC; address is the kernel-assigned EUI64 address from the RA prefix.
        case "$nd1_flags" in
            *M*) SLAAC_ADDR="" ;;
            *)   SLAAC_ADDR="${nd1_addr1:-}" ;;
        esac

        _debug_log "writing state file ${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv6ra.state"

        mkdir -p "$UPLINKMGR_STATE_DIR"
        _write_state_file "${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv6ra.state" \
            'gateway=%s\nlifetime=%s\ntimestamp=%s\naddress=%s\nprefix=%s\nplen=%s\n' \
            "$GW6" "$ND1_LIFETIME" "$(date +%s)" "$SLAAC_ADDR" "$ND1_PREFIX" "$ND1_PLEN"

        _signal_daemon
        ;;

    # IPv6 lease: write PD and IA_NA state files and signal daemon
    BOUND6|RENEW6|REBIND6)
        [ "$UPLINKMGR_IPV6_PD" = true ] || [ "$UPLINKMGR_IPV6_IA_NA" = true ] || return 0

        _debug_log "wants IPv6 PD or NA"

        DELEGATED_PREFIX="${new_dhcp6_ia_pd1_prefix1:-}"
        DELEGATED_LENGTH="${new_dhcp6_ia_pd1_prefix1_length:-}"
        VLTIME="${new_dhcp6_ia_pd1_prefix1_vltime:-}"
        PLTIME="${new_dhcp6_ia_pd1_prefix1_pltime:-}"

        if [ -n "$DELEGATED_PREFIX" ] && [ -n "$DELEGATED_LENGTH" ]; then
            _debug_log "writing PD state file ${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv6pd.state"
            mkdir -p "$UPLINKMGR_STATE_DIR"
            _write_state_file "${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv6pd.state" \
                'delegated_prefix=%s\ndelegated_length=%s\nvltime=%s\npltime=%s\ntimestamp=%s\n' \
                "$DELEGATED_PREFIX" "$DELEGATED_LENGTH" \
                "$VLTIME" "$PLTIME" "$(date +%s)"
        fi

        if [ -n "$new_dhcp6_ia_na1_ia_addr1" ]; then
            _debug_log "writing NA state file ${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv6na.state"
            mkdir -p "$UPLINKMGR_STATE_DIR"
            _write_state_file "${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv6na.state" \
                'address=%s\n' "$new_dhcp6_ia_na1_ia_addr1"
        else
            rm -f "${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv6na.state"
        fi

        _signal_daemon
        ;;

    # IPv6 expiry: remove all IPv6 state files and signal daemon
    EXPIRE6|STOP6)
        [ "$UPLINKMGR_IPV6_PD" = true ] || [ "$UPLINKMGR_IPV6_IA_NA" = true ] || return 0

        rm -f "${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv6ra.state"
        rm -f "${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv6pd.state"
        rm -f "${UPLINKMGR_STATE_DIR}/${UPLINKMGR_UPLINK_NAME}.ipv6na.state"
        _signal_daemon
        ;;

esac

return 0
