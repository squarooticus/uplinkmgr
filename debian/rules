#!/usr/bin/make -f

export PYBUILD_NAME = uplinkmgr

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_install:
	dh_auto_install
	# Entry-point scripts
	install -d debian/uplinkmgr/usr/sbin
	install -m 755 bin/uplinkmgr bin/uplinkmgr-setup \
	    debian/uplinkmgr/usr/sbin/
	# dhcpcd hook (linked at runtime into whichever dhcpcd-hooks directory
	# dhcpcd-base expects -- see debian/uplinkmgr.triggers and
	# hooks/dhcpcd-hook-link)
	install -d debian/uplinkmgr/usr/lib/uplinkmgr
	install -m 755 hooks/dhcpcd-hook hooks/dhcpcd-hook-link \
	    debian/uplinkmgr/usr/lib/uplinkmgr/
	# radvd systemd template unit file
	install -d debian/uplinkmgr/usr/lib/systemd/system
	install -m 644 systemd/radvd-uplinkmgr@.service \
	    debian/uplinkmgr/usr/lib/systemd/system/

# dh_installsystemd handles the uplinkmgr.service unit automatically
# (picks it up from debian/uplinkmgr.service).
