#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        if [ -d /run/systemd/system ]; then
            # Stop and disable per-uplink services before the package files
            # are removed (the generated .service files live in /etc/systemd/system/).
            for svc in /etc/systemd/system/dhcpcd-uplinkmgr-*.service \
                       /etc/systemd/system/radvd-uplinkmgr-*.service; do
                [ -f "$svc" ] || continue
                name=$(basename "$svc")
                systemctl disable --now "$name" 2>/dev/null || true
            done
        fi
        ;;
esac

#DEBHELPER#
