#!/bin/sh
set -e

case "$1" in
    remove|deconfigure)
        if [ -d /run/systemd/system ]; then
            # Disable and stop radvd units
            for unit in $(systemctl list-units --all 'radvd-uplinkmgr@*' --no-legend | awk '{print $1;}'); do
                systemctl disable --now "$unit" || true
            done
        fi
        # Strip our symlink from every candidate dhcpcd-hooks dir before
        # dpkg removes /usr/lib/uplinkmgr/dhcpcd-hook, so no dangling
        # symlink is left behind.
        if [ -x /usr/lib/uplinkmgr/dhcpcd-hook-link ]; then
            /usr/lib/uplinkmgr/dhcpcd-hook-link --remove || true
        fi
        ;;
esac

#DEBHELPER#
