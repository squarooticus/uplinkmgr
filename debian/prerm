#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        if [ -d /run/systemd/system ]; then
            # Stop radvd units before the generated .service files are removed.
            for svc in /etc/systemd/system/radvd-uplinkmgr-*.service; do
                [ -f "$svc" ] || continue
                name=$(basename "$svc")
                systemctl disable --now "$name" 2>/dev/null || true
            done
            # Stop dhcpcd; postrm will restore /etc/dhcpcd.conf from backup.
            systemctl stop dhcpcd.service 2>/dev/null || true
        fi
        ;;
esac

#DEBHELPER#
