#!/bin/sh
set -e

case "$1" in
    configure)
        if [ ! -f /etc/uplinkmgr/uplinkmgr.yaml ]; then
            # Brief instructions on how to configure and enable uplinkmgr
            echo "uplinkmgr: Example config at /usr/share/doc/uplinkmgr/uplinkmgr.yaml.example"
            echo "uplinkmgr: Copy to /etc/uplinkmgr/uplinkmgr.yaml and modify where necessary"
            echo "uplinkmgr: Possibly add /etc/uplinkmgr/dhcpcd.conf.{head,tail} to tweak dhcpcd config"
            echo "uplinkmgr: Finally, run 'uplinkmgr-setup' to enable"
        else
            # (Re)generate config files if already configured
            uplinkmgr-setup || true
        fi
        /usr/lib/uplinkmgr/dhcpcd-hook-link || \
            echo "uplinkmgr: warning: failed to link dhcpcd exit hook" >&2
        ;;
    triggered)
        # dhcpcd-base added/removed files in one of its hooks directories
        # (see debian/uplinkmgr.triggers) -- re-check which one it owns.
        /usr/lib/uplinkmgr/dhcpcd-hook-link || \
            echo "uplinkmgr: warning: failed to link dhcpcd exit hook" >&2
        ;;
esac

#DEBHELPER#

case "$1" in
    configure)
        if [ -d /run/systemd/system ]; then
            # Make sure the newly-installed/updated unit files are re-read
            systemctl daemon-reload || true
        fi
        ;;
esac
